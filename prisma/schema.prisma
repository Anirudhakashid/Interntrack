// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  branch    String?  // e.g., "Computer Science", "Mechanical", etc.
  division  String?  // e.g., "A", "B", "C"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Student relationships
  internshipForms InternshipForm[] @relation("StudentForms")
  attendances     Attendance[]

  // Teacher relationships
  approvedForms InternshipForm[] @relation("TeacherForms")

  @@map("users")
}

model InternshipForm {
  id                 String             @id @default(cuid())
  studentId          String
  studentName        String?
  studentClass       String?            // FE/SE/TE/BE
  studentBranch      String?
  studentDivision    String?
  teacherId          String
  companyName        String
  companyLocation    String?
  domain             String?
  durationWeeks      Int?
  startDate          DateTime?
  endDate            DateTime?
  stipend            String?            // paid/unpaid
  stipendAmount      Int?
  mode               String?            // online/offline/hybrid
  offerLetterURL     String
  deptCoordinatorEmail String? @map("coordinatorEmail")
  hrEmail            String
  status             InternshipStatus   @default(PENDING)
  isActive           Boolean           @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  student      User         @relation("StudentForms", fields: [studentId], references: [id], onDelete: Cascade)
  teacher      User         @relation("TeacherForms", fields: [teacherId], references: [id])
  attendances  Attendance[]

  @@map("internship_forms")
}

model Attendance {
  id               String            @id @default(cuid())
  studentId        String
  internshipFormId String
  date             DateTime          @default(now())
  status           AttendanceStatus  @default(PENDING)
  verificationToken String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  student        User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internshipForm InternshipForm    @relation(fields: [internshipFormId], references: [id], onDelete: Cascade)
  logs           VerificationLog[]

  @@map("attendances")
}

model VerificationLog {
  id           String   @id @default(cuid())
  attendanceId String
  ipAddress    String
  location     String?
  userAgent    String?
  action       String
  timestamp    DateTime @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("verification_logs")
}

model DepartmentCoordinator {
  id        String   @id @default(cuid())
  branch    String   @unique
  email     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("department_coordinators")
}

enum UserRole {
  STUDENT
  TEACHER
}

enum InternshipStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum AttendanceStatus {
  PENDING
  VERIFIED
  ABSENT
}
